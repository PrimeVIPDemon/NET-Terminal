for (var i = 0; i < columns; i++) {
    drops[i] = random(height);
}
var matrixOverlay = function() {
    textSize(fontSize);
    for (var i = 0; i < drops.length; i++) {
        var char = matrixLetters[floor(random(matrixLetters.length))];
        fill(0, 255, 0, 180);
        text(char, i * fontSize, drops[i]);
        drops[i] += fontSize;
        if (drops[i] > height && random() > 0.975) { drops[i] = 0; }
    }
};

// Glitch Effect
var glitch = function() {
