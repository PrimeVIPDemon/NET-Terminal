};

// Radar Map
var radarSweepAngle = 0;
var drawRadar = function(x, y, r) {
    noFill();
    stroke(0, 255, 0, 80);
    ellipse(x, y, r*2, r*2);
    ellipse(x, y, r*1.5, r*1.5);
    ellipse(x, y, r, r);
    stroke(0, 255, 0);
    var endX = x + cos(radarSweepAngle) * r;
    var endY = y + sin(radarSweepAngle) * r;
    line(x, y, endX, endY);
